# Kopioi tämä tiedosto nimelle .env ja täytä oikeat arvot
# docker-compose lukee automaattisesti .env-tiedoston

# Django
DJANGO_ENV=prod
DJANGO_SECRET_KEY=vaihda-tama-satunnaiseen-pitkaan-merkkijonoon
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DATABASE_NAME=QA-results
DATABASE_USER=postgres
DATABASE_PASSWORD=vaihda-tama

# Orthanc DICOM server
ORTHANC_USERNAME=admin
ORTHANC_PASSWORD=vaihda-tama

# OpenAI GPT-4o (AI-assistentti)
OPENAI_API_KEY=sk-proj-...

# Slack-ilmoitukset
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
