# AutoQAD - Environment Variables
# Copy this file to .env and fill in real values

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,host.docker.internal

# PostgreSQL
DATABASE_NAME=QA-results
DATABASE_USER=postgres
DATABASE_PASSWORD=your-db-password
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Orthanc DICOM server
ORTHANC_URL=http://localhost:8042
ORTHANC_USERNAME=admin
ORTHANC_PASSWORD=your-orthanc-password

# Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# OpenAI (AI assistant)
OPENAI_API_KEY=sk-your-openai-api-key
